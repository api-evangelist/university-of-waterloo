      "type": "string"
    },
    "courseOfferNumber": {
      "type": "int32"
    },
    "termCode": {
      "type": "string"
    },
    "termName": {
      "type": "string"
    },
    "subjectCode": {
      "type": "string"
    },
    "catalogNumber": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "gradingBasis": {
      "type": "string"
    },
